# Ekošarna — primer konfiguracije
# Kopiraj u .env i popuni pravim vrednostima. NE commitovati .env!

# ── Baza podataka ──
DB_HOST=localhost
DB_NAME=ekosarna_db
DB_USER=ekosarna_user
DB_PASS=
DB_PORT=3306

# ── SMTP (slanje mailova) ──
SMTP_HOST=mail.ekosarna.com
SMTP_PORT=465
SMTP_USER=info@ekosarna.com
SMTP_PASS=

# ── IMAP (Sent folder) ──
IMAP_HOST=mail.ekosarna.com
IMAP_PORT=993
IMAP_SENT=INBOX.Sent

# ── Web Push (VAPID ključevi) ──
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@ekosarna.com

# ── Telegram bot ──
TELEGRAM_BOT_TOKEN=

# ── Anthropic API ──
ANTHROPIC_API_KEY=
